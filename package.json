{
  "name": "after-sales-platform",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm:server\" \"npm:web\"",
    "server": "node --no-warnings --watch server/index.js",
    "web": "vite --host 0.0.0.0",
    "dev:server": "node --no-warnings --watch server/index.js",
    "dev:web": "vite --host 0.0.0.0",
    "build": "vite build",
    "preview": "vite preview --host 0.0.0.0",
    "start": "node --no-warnings server/index.js",
    "sync:orders": "node --no-warnings server/sync.js",
    "test:parser": "node --no-warnings server/parser.test.js"
  },
  "dependencies": {
    "@ant-design/icons-vue": "^7.0.1",
    "@vitejs/plugin-vue": "^5.2.4",
    "ant-design-vue": "^4.2.6",
    "cheerio": "^1.0.0",
    "concurrently": "^9.1.2",
    "cos-nodejs-sdk-v5": "^2.15.4",
    "echarts": "^6.1.0",
    "express": "^4.21.2",
    "multer": "^2.0.2",
    "vite": "^6.3.5",
    "vue": "^3.5.13"
  }
}
